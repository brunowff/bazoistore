{
  "info": {
    "name": "Baozi Store API",
    "description": "Collection completa para testar a API REST da Baozi Store. Cobre todos os endpoints de Clientes, Produtos e Pedidos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Clientes",
      "item": [
        {
          "name": "Criar Cliente",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Bruno RU123456\",\n  \"clienteDesde\": \"2026-05-10\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/clientes",
              "host": ["{{baseUrl}}"],
              "path": ["clientes"]
            },
            "description": "Cria um novo cliente. Retorna 201 Created com o objeto criado incluindo o ID gerado."
          },
          "response": []
        },
        {
          "name": "Listar Clientes",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/clientes",
              "host": ["{{baseUrl}}"],
              "path": ["clientes"]
            },
            "description": "Retorna a lista completa de todos os clientes cadastrados."
          },
          "response": []
        },
        {
          "name": "Buscar Cliente por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/clientes/1",
              "host": ["{{baseUrl}}"],
              "path": ["clientes", "1"]
            },
            "description": "Retorna um cliente específico pelo ID. Substitua o '1' pelo ID desejado. Retorna 404 se não encontrado."
          },
          "response": []
        },
        {
          "name": "Atualizar Cliente",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Bruno Atualizado RU123456\",\n  \"clienteDesde\": \"2026-01-01\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/clientes/1",
              "host": ["{{baseUrl}}"],
              "path": ["clientes", "1"]
            },
            "description": "Atualiza os dados de um cliente existente pelo ID. Retorna 404 se não encontrado."
          },
          "response": []
        },
        {
          "name": "Deletar Cliente",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/clientes/1",
              "host": ["{{baseUrl}}"],
              "path": ["clientes", "1"]
            },
            "description": "Remove um cliente pelo ID. Retorna 204 No Content em caso de sucesso, 404 se não encontrado."
          },
          "response": []
        }
      ]
    },
