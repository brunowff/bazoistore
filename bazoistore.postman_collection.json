                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/pedidos",
              "host": ["{{baseUrl}}"],
              "path": ["pedidos"]
            },
            "description": "Cria um novo pedido associando um cliente a um produto com uma quantidade. Certifique-se de que o clienteId e produtoId existam antes. Retorna 201 Created."
          },
          "response": []
        },
        {
          "name": "Listar Pedidos",
          "request": {
            "method": "GET",
